#!/usr/bin/env bash
# normalize-readwise
# Normalizes Readwise filenames so qmd can index them without choking.
# Logs all renames to ~/.cache/qmd/readwise-renames.log.
# If the same original filename keeps appearing, Readwise is re-creating it
# after each rename — that file needs a different fix.

VAULT="/Users/jolilius/home/doc/vaults/Projects2024-2025"
READWISE_DIR="$VAULT/2 Areas/Readwise"
RENAME_LOG="${HOME}/.cache/qmd/readwise-renames.log"

mkdir -p "$(dirname "$RENAME_LOG")"

log_rename() { echo "[$(date -Iseconds)] RENAMED  \"$1\"  →  \"$2\"" >> "$RENAME_LOG"; }
log_skip()   { echo "[$(date -Iseconds)] SKIP     collision: \"$1\" (source: \"$2\")" >> "$RENAME_LOG"; }

normalize_name() {
    local name="${1%.md}"
    name="${name//◙/}"           # remove ◙ separator (Readwise truncation artifact)
    name="${name// – / - }"      # em-dash → hyphen
    name="${name//#/}"           # remove hash
    name="${name//\[/}"          # remove [
    name="${name//\]/}"          # remove ]
    name="${name//  / }"         # collapse double spaces
    name="${name%.}"             # strip trailing dot
    name="${name:0:120}"         # truncate to 120 chars
    name="${name%[[:space:]]}"   # trim trailing space
    printf '%s' "$name"
}

find "$READWISE_DIR" -name "*.md" | while IFS= read -r filepath; do
    dir=$(dirname "$filepath")
    filename=$(basename "$filepath")
    normalized="$(normalize_name "$filename").md"
    [[ "$filename" == "$normalized" ]] && continue
    if [[ -f "$dir/$normalized" ]]; then
        log_skip "$normalized" "$filename"
        continue
    fi
    mv "$filepath" "$dir/$normalized"
    log_rename "$filename" "$normalized"
done
