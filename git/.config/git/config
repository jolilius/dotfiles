[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[user]
	name = Johan Lilius

[init]
	defaultBranch = main

[include]
	path = ~/.config/git/local
[url "git@github.com:"]
	insteadOf = https://github.com/
[ghq]
	root = /Users/jolilius/home/src

[alias]
	# Status & navigation
	st      = status -sb
	br      = branch -vv
	last    = log -1 HEAD --stat
	co      = checkout
	cob     = checkout -b

	# Log / history
	lg      = log --oneline --graph --decorate --all
	lp      = log --oneline -20
	who     = shortlog -sn --no-merges

	# Commit shortcuts
	cm      = commit -m
	ca      = commit --amend --no-edit

	# Undo / fixup
	undo    = reset --soft HEAD~1
	unstage = restore --staged
	wip     = !git add -A && git commit -m "WIP [skip ci]"
	unwip   = !git log -1 --format='%s' | grep -q 'WIP' && git reset HEAD~1

	# Housekeeping
	aliases = config --get-regexp '^alias\\.'
	ignored = ls-files --others --ignored --exclude-standard
	gone    = !git fetch -p && git branch -vv | grep ': gone]' | awk '{print $1}' | xargs git branch -d
